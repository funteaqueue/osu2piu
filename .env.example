# Copy to `.env` to override any default. Every default below is
# repo-relative — `docker compose up --build` works right after a fresh
# clone with no `.env` at all (patterns.pkl/corpus_stats.json are checked
# into git, so they're already there; publish writes into ./publish; the
# pump noteskin sprites ship in ./noteskin, so the real in-game arrows
# render out of the box).

# host ports each service is published on. Override any of these if the
# default is already in use ("port is already allocated"). Only the host
# side changes — nothing inside the containers needs reconfiguring.
#
#   WEB_PORT       the web UI. This is the ONLY published port in prod
#                  (`make prod`) — reach the app at http://<host>:<WEB_PORT>.
#                  Also the API-server port in dev.
#   ENGINE_PORT    dev only (compose.dev.yml) — the uvicorn API.
#   FRONTEND_PORT  dev only (compose.dev.yml) — the vite dev server.
#WEB_PORT=8080
#ENGINE_PORT=8000
#FRONTEND_PORT=5173

# host path to the harvested pattern library (see README: build-patterns)
#PATTERNS_FILE=./patterns.pkl

# host path to the corpus metrics index (see README: build-corpus-stats)
#CORPUS_STATS_FILE=./corpus_stats.json

# host directory where uploaded projects + edits are stored
#PROJECTS_DIR=./projects

# host directory "publish to Songs" writes into — point this at your
# StepMania/PIU install's Songs folder. Absolute host path, e.g.
#   Linux:   /srv/stepmania/Songs/ZZ.OSU CONVERTS
#   Windows: D:/piu/XSanity/Songs/ZZ.OSU CONVERTS
# Defaults to the repo-local ./publish if unset.
#PUBLISH_DIR=./publish

# host directory with a StepMania pump noteskin (NoteSkins/pump/<name>).
# Defaults to the repo-local ./noteskin, which already ships the pump
# sprites — only set this to swap in a different noteskin from your own
# install, e.g.
#   Linux:   /srv/stepmania/NoteSkins/pump/default
#   Windows: D:/piu/XSanity/NoteSkins/pump/default
#NOTESKIN_SOURCE_DIR=./noteskin

# Official osu! API v2 credentials, used only for beatmapset search. Register
# an OAuth application at https://osu.ppy.sh/home/account/edit and keep the
# client secret server-side. Beatmap downloads still happen on osu!'s website.
#OSU_CLIENT_ID=
#OSU_CLIENT_SECRET=

# Optional: raw `osu_session` cookie value (or complete Cookie header) used to
# try the official website download before falling back to mirrors. Treat this
# like a password. It is never sent to the frontend.
#OSU_SESSION_COOKIE=
# Host path to a Mozilla/Netscape cookies.txt export. Docker mounts it
# read-only; the backend extracts only osu_session at startup.
#OSU_COOKIES_FILE=./cookies.txt
